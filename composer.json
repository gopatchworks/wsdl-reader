{
    "name": "gopatchworks/wsdl-reader",
    "description": "A WSDL reader in PHP",
    "type": "library",
    "autoload": {
        "psr-4": {
            "Soap\\WsdlReader\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Soap\\WsdlReader\\Test\\": "tests/"
        }
    },
    "require": {
        "php": "^8.1",
        "ext-dom": "*",
        "goetas-webservices/xsd-reader": "^0.4.1",
        "gopatchworks/soap-engine": "^3.0.0",
        "php-soap/wsdl": "^1.18.0",
        "veewee/xml": "3.6.0",
        "symfony/console": "^7.0",
        "php-standard-library/php-standard-library": "4.3.0"
    },
    "require-dev": {
        "veewee/composer-run-parallel": "^1.2",
        "symfony/var-dumper": "^6.1",
        "psalm/plugin-symfony": "^5.0",
        "php-standard-library/psalm-plugin": "^2.2",
        "vimeo/psalm": "^6.16.1"
    },
    "license": "MIT",
    "authors": [
        {
            "name": "Toon Verwerft",
            "email": "toonverwerft@gmail.com"
        }
    ],
    "config": {
        "allow-plugins": {
            "veewee/composer-run-parallel": true
        }
    },
    "repositories": [
        {
            "type": "vcs",
            "url": "git@github.com:gopatchworks/soap-engine.git"
        }
    ]
}
